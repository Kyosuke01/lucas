# =============================================================
# LUCAS — Configuration d'environnement
# Copier ce fichier en .env avant de lancer setup
# Ne jamais committer le fichier .env dans Git
# =============================================================

# --- General ---
LUCAS_ENV=development          # development | production
LUCAS_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# --- Ports exposes ---
OLLAMA_PORT=11434              # API Ollama
OPEN_WEBUI_PORT=8080           # Interface Open WebUI (chat)

# --- Ollama ---
OLLAMA_HOST=ollama             # Nom du service Docker (ne pas modifier)
OLLAMA_DEFAULT_MODEL=llama3.1:8b  # Defini automatiquement par setup

# --- Open WebUI ---
WEBUI_SECRET_KEY=change_me_with_a_random_string_32_chars  # Genere automatiquement par setup
ENABLE_SIGNUP=false            # false = acces sans compte requis

# --- Personnalisation Open WebUI ---
WEBUI_NAME=LUCAS
WEBUI_URL=http://localhost:8080
DEFAULT_LOCALE=fr

# --- Compte admin Open WebUI (cree automatiquement au 1er demarrage) ---
# Ces variables sont ignorees si un compte existe deja
WEBUI_ADMIN_EMAIL=admin@lucas.local
WEBUI_ADMIN_PASSWORD=change_me_admin_password
WEBUI_ADMIN_NAME=Admin

# --- Whisper STT (Phase 2 - voix) ---
WHISPER_MODEL=base             # tiny | base | small | medium | large
WHISPER_LANGUAGE=fr

# --- Piper TTS (Phase 2 - voix) ---
PIPER_VOICE=fr_FR-siwis-medium

# --- Securite ---
LUCAS_ACTION_CONFIRM=true      # Demander confirmation pour actions sensibles
LUCAS_ACTION_WHITELIST=true    # Utiliser la liste blanche d'actions