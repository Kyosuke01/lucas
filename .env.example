# =============================================================
# LUCAS — Configuration d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# =============================================================

# --- Général ---
LUCAS_ENV=development          # development | production
LUCAS_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# --- Ports exposés ---
LUCAS_DASHBOARD_PORT=3000      # Interface LUCAS
OLLAMA_PORT=11434              # API Ollama
OPEN_WEBUI_PORT=8080           # Interface Open WebUI

# --- Ollama ---
OLLAMA_HOST=ollama
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# --- Open WebUI ---
WEBUI_SECRET_KEY=change_me_with_a_random_string_32_chars
ENABLE_SIGNUP=false

# --- Whisper STT ---
WHISPER_MODEL=base             # tiny | base | small | medium | large
WHISPER_LANGUAGE=fr

# --- Piper TTS ---
PIPER_VOICE=fr_FR-siwis-medium

# --- Sécurité ---
LUCAS_ACTION_CONFIRM=true      # Demander confirmation pour actions sensibles
LUCAS_ACTION_WHITELIST=true    # Utiliser la liste blanche d'actions
